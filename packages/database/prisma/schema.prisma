generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ReadingFormat {
  COMIC
  EPUB
}

enum ReadingStatus {
  WANT
  READING
  FINISHED
}

enum FileHashStatus {
  FULL
  PARTIAL_PENDING
  FAILED
}

enum CoverStatus {
  PENDING
  READY
  FAILED
}

enum BookImportStatus {
  PENDING
  PARSING
  COMPLETED
  FAILED
}

enum BookOrigin {
  MANUAL
  WATCH
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String
  passwordHash String
  role         String            @default("admin")
  sessions     Session[]
  progresses   ReadingProgress[]
  libraryProgresses LibraryReadingProgress[]
  readerPreferences ReaderPreference[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonitorFolder {
  id          String     @id @default(cuid())
  name        String
  rootPath    String     @unique
  enabled     Boolean    @default(true)
  ignorePatterns String?  @db.Text
  ignoreHidden Boolean    @default(true)
  minFileSizeBytes Int     @default(10240)
  description String?
  books       Book[]
  works       LibraryWork[]
  editions    LibraryEdition[]
  importTasks ImportTask[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model LibraryWork {
  id               String         @id @default(cuid())
  monitorFolderId  String?
  monitorFolder    MonitorFolder? @relation(fields: [monitorFolderId], references: [id], onDelete: SetNull)
  origin           BookOrigin     @default(MANUAL)
  title            String
  normalizedTitle  String
  author           String?
  normalizedAuthor String?
  description      String?        @db.Text
  workType         ReadingFormat
  status           ReadingStatus  @default(WANT)
  tags             String         @db.Text
  coverPath        String?
  coverStatus      CoverStatus    @default(PENDING)
  hidden           Boolean        @default(false)
  organized        Boolean        @default(false)
  primaryEditionId String?
  mergeKey         String?
  editions         LibraryEdition[]
  progresses       LibraryReadingProgress[]
  importTasks      ImportTask[]
  shelves          ShelfWork[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([workType])
  @@index([title])
  @@index([normalizedTitle])
  @@index([normalizedAuthor])
  @@index([hidden])
  @@index([organized])
  @@index([monitorFolderId])
  @@unique([mergeKey])
}

model LibraryEdition {
  id               String           @id @default(cuid())
  workId           String
  work             LibraryWork      @relation(fields: [workId], references: [id], onDelete: Cascade)
  monitorFolderId  String?
  monitorFolder    MonitorFolder?   @relation(fields: [monitorFolderId], references: [id], onDelete: SetNull)
  origin           BookOrigin       @default(MANUAL)
  format           ReadingFormat
  versionName      String
  versionKey       String
  sourceGroupKey   String?
  description      String?          @db.Text
  language         String?
  publisher        String?
  publishedAt      String?
  identifier       String?
  isbn             String?
  importStatus     BookImportStatus @default(PENDING)
  importError      String?          @db.Text
  sizeBytes        BigInt           @default(0)
  pageCount        Int?
  chapterCount     Int?
  coverPath        String?
  coverStatus      CoverStatus      @default(PENDING)
  primary          Boolean          @default(false)
  hidden           Boolean          @default(false)
  volumes          LibraryVolume[]
  files            LibraryFile[]
  readingUnits     LibraryReadingUnit[]
  metadataItems    LibraryMetadata[]
  progresses       LibraryReadingProgress[]
  importTasks      ImportTask[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([workId, versionKey])
  @@index([workId, primary])
  @@index([format])
  @@index([identifier])
  @@index([isbn])
  @@index([sourceGroupKey])
  @@index([monitorFolderId])
}

model LibraryVolume {
  id            String          @id @default(cuid())
  editionId     String
  edition       LibraryEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  title         String
  volumeIndex   Float?
  sortOrder     Int            @default(0)
  pageCount     Int?
  chapterCount  Int?
  coverPath     String?
  files         LibraryFile[]
  readingUnits  LibraryReadingUnit[]
  progresses    LibraryReadingProgress[]
  importTasks   ImportTask[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([editionId, sortOrder])
  @@index([editionId, volumeIndex])
}

model LibraryFile {
  id           String         @id @default(cuid())
  editionId    String
  edition      LibraryEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  volumeId     String?
  volume       LibraryVolume? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  path         String         @unique
  filePathHash String?        @unique
  fingerprint  String?
  fullHash     String?        @unique
  hashStatus   FileHashStatus @default(FAILED)
  mtimeMs      BigInt         @default(0)
  kind         ReadingFormat
  mimeType     String
  sizeBytes    BigInt         @default(0)
  sortOrder    Int            @default(0)
  readingUnits LibraryReadingUnit[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([editionId, sortOrder])
  @@index([volumeId, sortOrder])
  @@index([fingerprint])
  @@index([fullHash])
  @@index([sizeBytes, mtimeMs])
}

model Book {
  id            String            @id @default(cuid())
  monitorFolderId String?
  monitorFolder   MonitorFolder?  @relation(fields: [monitorFolderId], references: [id], onDelete: SetNull)
  origin        BookOrigin        @default(MANUAL)
  title         String
  author        String?
  description   String?           @db.Text
  seriesName    String?
  seriesIndex   Float?
  format        ReadingFormat
  status        ReadingStatus     @default(WANT)
  tags          String            @db.Text
  coverPath     String?
  coverStatus   CoverStatus       @default(PENDING)
  hidden        Boolean           @default(false)
  organized     Boolean           @default(false)
  managedFilePath String
  contentHash   String            @unique
  sizeBytes     BigInt            @default(0)
  pageCount     Int?
  chapterCount  Int?
  language      String?
  publisher     String?
  publishedAt   String?
  identifier    String?
  isbn          String?
  importStatus  BookImportStatus @default(PENDING)
  importError   String? @db.Text
  files         BookFile[]
  chapters      BookChapter[]
  readingUnits  ReadingUnit[]
  assets        BookAsset[]
  metadataItems BookMetadata[]
  progresses    ReadingProgress[]
  importTasks   ImportTask[]
  shelves       ShelfBook[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([format])
  @@index([title])
  @@index([author])
  @@index([hidden])
  @@index([organized])
  @@index([monitorFolderId])
}

model BookFile {
  id           String         @id @default(cuid())
  bookId       String
  book         Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  path         String
  filePathHash String?        @unique
  fingerprint  String?
  fullHash     String?
  hashStatus   FileHashStatus @default(FAILED)
  mtimeMs      BigInt         @default(0)
  kind         ReadingFormat
  mimeType     String
  sizeBytes    BigInt         @default(0)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([bookId, path])
  @@index([bookId, sortOrder])
  @@index([fingerprint])
  @@index([fullHash])
  @@index([sizeBytes, mtimeMs])
}

model ImportTask {
  id            String         @id @default(cuid())
  monitorFolderId String?
  monitorFolder   MonitorFolder? @relation(fields: [monitorFolderId], references: [id], onDelete: SetNull)
  bookId        String?
  book          Book?          @relation(fields: [bookId], references: [id], onDelete: SetNull)
  workId        String?
  work          LibraryWork?   @relation(fields: [workId], references: [id], onDelete: SetNull)
  editionId     String?
  edition       LibraryEdition? @relation(fields: [editionId], references: [id], onDelete: SetNull)
  volumeId      String?
  volume        LibraryVolume? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  origin        BookOrigin
  status        BookImportStatus @default(PENDING)
  originalName  String?
  sourcePath    String
  managedFilePath String?
  contentHash   String?
  progress      Int            @default(0)
  duplicate     Boolean        @default(false)
  duration      Int            @default(0)
  errorSummary  String?        @db.Text
  message       String?
  startedAt     DateTime?
  finishedAt    DateTime?
  logs          ImportLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([monitorFolderId, status])
  @@index([status, createdAt])
  @@index([contentHash])
  @@index([workId])
  @@index([editionId])
  @@index([volumeId])
}

model ImportLog {
  id         String   @id @default(cuid())
  importTaskId String
  importTask   ImportTask @relation(fields: [importTaskId], references: [id], onDelete: Cascade)
  level      String   @default("info")
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([importTaskId, createdAt])
}

model ReadingProgress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  readerType String
  position   String   @default("0")
  page       Int?
  percent    Float    @default(0)
  extra      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, bookId])
  @@index([bookId])
}

model ReaderPreference {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerType String
  settings   String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, readerType])
  @@index([userId])
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shelf {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  books       ShelfBook[]
  works       ShelfWork[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([updatedAt])
}

model ShelfWork {
  shelfId   String
  workId    String
  shelf     Shelf       @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  work      LibraryWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@id([shelfId, workId])
  @@index([workId])
  @@index([shelfId, createdAt])
}

model ShelfBook {
  shelfId   String
  bookId    String
  shelf     Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([shelfId, bookId])
  @@index([bookId])
  @@index([shelfId, createdAt])
}


model BookChapter {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  title     String
  href      String
  mediaType String?
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId, sortOrder])
}

model BookMetadata {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  source    String
  rawJson   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
}

model ReadingUnit {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  unitType     String
  title        String
  href         String
  filePath     String?
  mediaType    String?
  sortOrder    Int
  width        Int?
  height       Int?
  size         BigInt?
  metadataJson String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookId, sortOrder])
  @@index([bookId, unitType])
}

model BookAsset {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  assetType String
  filePath  String
  url       String?
  mediaType String?
  width     Int?
  height    Int?
  size      BigInt?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId, assetType])
  @@index([bookId, sortOrder])
}

model LibraryReadingUnit {
  id           String         @id @default(cuid())
  editionId    String
  edition      LibraryEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  volumeId     String?
  volume       LibraryVolume? @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  fileId       String?
  file         LibraryFile?   @relation(fields: [fileId], references: [id], onDelete: SetNull)
  unitType     String
  title        String
  href         String
  mediaType    String?
  sortOrder    Int
  width        Int?
  height       Int?
  size         BigInt?
  metadataJson String         @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([editionId, sortOrder])
  @@index([editionId, unitType])
  @@index([volumeId, sortOrder])
  @@index([fileId, sortOrder])
}

model LibraryMetadata {
  id        String         @id @default(cuid())
  editionId String
  edition   LibraryEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  source    String
  rawJson   String         @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([editionId])
}

model LibraryReadingProgress {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workId     String
  work       LibraryWork     @relation(fields: [workId], references: [id], onDelete: Cascade)
  editionId  String
  edition    LibraryEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  volumeId   String?
  volume     LibraryVolume?  @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  readerType String
  position   String          @default("0")
  page       Int?
  percent    Float           @default(0)
  extra      String          @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, editionId])
  @@index([workId])
  @@index([editionId])
  @@index([volumeId])
}
