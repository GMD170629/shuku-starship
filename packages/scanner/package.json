{
  "name": "@shuku/scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./path-security-service": {
      "types": "./src/path-security-service.ts",
      "import": "./src/path-security-service.ts",
      "default": "./src/path-security-service.ts"
    },
    "./cover-service": {
      "types": "./src/cover-service.ts",
      "import": "./src/cover-service.ts",
      "default": "./src/cover-service.ts"
    },
    "./managed-import": {
      "types": "./src/managed-import.ts",
      "import": "./src/managed-import.ts",
      "default": "./src/managed-import.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^5.21.1",
    "@shuku/database": "workspace:*",
    "chokidar": "^4.0.3",
    "ignore": "^7.0.5",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.7.284",
    "sharp": "^0.34.5",
    "yauzl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.6",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
